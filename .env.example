# Copia este archivo como .env y completa los valores

# =============================================================
# PostgreSQL (REQUERIDO para produccion/VPS)
# =============================================================
DATABASE_URL=postgresql://usuario:password@127.0.0.1:5432/btc_predictor

# =============================================================
# Recoleccion de datos
# =============================================================
# true  = escribe datos en la DB (produccion/VPS)
# false = no escribe datos, solo ejecuta el bot (desarrollo local)
ENABLE_DATA_COLLECTION=false

# =============================================================
# URL de la DB de produccion para entrenamiento
# =============================================================
# Cuando entrenas el modelo en local, usa esta URL para leer
# datos directamente de la DB de produccion en el VPS.
# Si no se define, el trainer usa DATABASE_URL.
TRAINING_DATABASE_URL=postgresql://usuario:password@ip_vps:5432/btc_predictor

# =============================================================
# Telegram (notificaciones y comandos)
# =============================================================
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# =============================================================
# Polymarket API Keys (solo para TRADING REAL, no para paper)
# =============================================================
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=

# =============================================================
# Configuracion del bot
# =============================================================
BOT_INITIAL_CAPITAL=1000
BOT_MIN_CONFIDENCE=0.55
BOT_MAX_RISK=0.05
BOT_KELLY_FRACTION=0.35
