# Copia este archivo como .env y completa los valores

# =============================================================
# PostgreSQL (REQUERIDO para produccion/VPS)
# =============================================================
# Si DATABASE_URL existe -> usa PostgreSQL
# Si no existe -> usa SQLite local (solo para desarrollo)
# DATABASE_URL=postgresql://bot:changeme@localhost:5432/bot_cripto

# Credenciales para docker-compose (el bot usa DATABASE_URL)
POSTGRES_DB=bot_cripto
POSTGRES_USER=bot
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# =============================================================
# Polymarket API Keys (solo para TRADING, no para pipeline de datos)
# =============================================================
# Se obtienen desde: https://polymarket.com/settings -> API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# --- Wallet (solo para trading real) ---
POLY_PRIVATE_KEY=

# =============================================================
# Configuracion del bot
# =============================================================
BOT_RISK_FRACTION=0.01
BOT_MIN_CONFIDENCE=0.58
BOT_PAPER_MODE=true
