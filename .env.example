# Copia este archivo como .env y completa los valores

# =============================================================
# PostgreSQL (REQUERIDO para produccion/VPS)
# =============================================================
# Si DATABASE_URL existe -> usa PostgreSQL
# Si no existe -> usa SQLite local (solo para desarrollo)
DATABASE_URL=postgresql://usuario:password@127.0.0.1:5432/btc_predictor

# =============================================================
# Polymarket API Keys (solo para TRADING, no para pipeline de datos)
# =============================================================
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=

# =============================================================
# Configuracion del bot
# =============================================================
BOT_RISK_FRACTION=0.01
BOT_MIN_CONFIDENCE=0.58
BOT_PAPER_MODE=true
