# Copia este archivo como .env y completa los valores
# cuando llegues a la Fase de ejecucion (trading real)

# --- Polymarket API Keys (solo necesarios para TRADING, no para datos) ---
# Se obtienen desde: https://polymarket.com/settings -> API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# --- Wallet (solo para trading real) ---
# Private key de la wallet Polygon asociada a tu cuenta Polymarket
POLY_PRIVATE_KEY=

# --- Configuracion del bot ---
# Fraccion del capital a arriesgar por operacion (0.01 = 1%)
BOT_RISK_FRACTION=0.01

# Confianza minima del modelo para entrar (0.0 a 1.0)
BOT_MIN_CONFIDENCE=0.58

# Modo paper trading (true = simula sin enviar ordenes reales)
BOT_PAPER_MODE=true
